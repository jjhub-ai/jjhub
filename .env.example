# JJHub Community Edition — Environment Variables
# Copy this file to .env and adjust values as needed.

# Database (used by docker-compose and the server)
JJHUB_DB_HOST=db
JJHUB_DB_PORT=5432
JJHUB_DB_NAME=jjhub
JJHUB_DB_USER=jjhub
JJHUB_DB_PASSWORD=jjhub

# Server
JJHUB_PORT=3000
JJHUB_DATA_DIR=/app/data

# Auth (optional — uncomment and set for GitHub OAuth)
# JJHUB_GITHUB_CLIENT_ID=
# JJHUB_GITHUB_CLIENT_SECRET=
# JJHUB_AUTH_KEY_AUTH_DOMAIN=localhost

# Session secret (generate a random string for production)
# JJHUB_SESSION_SECRET=change-me-in-production
