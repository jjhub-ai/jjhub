{
  "name": "jjhub",
  "displayName": "JJHub",
  "description": "JJHub integration for Visual Studio Code — issues, landing requests, bookmarks, and sync status.",
  "version": "0.0.1",
  "publisher": "jjhub-ai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jjhub.openDashboard",
        "title": "JJHub: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "jjhub.createIssue",
        "title": "JJHub: Create Issue",
        "icon": "$(add)"
      },
      {
        "command": "jjhub.search",
        "title": "JJHub: Search",
        "icon": "$(search)"
      },
      {
        "command": "jjhub.syncNow",
        "title": "JJHub: Sync Now",
        "icon": "$(sync)"
      },
      {
        "command": "jjhub.openWorkspace",
        "title": "JJHub: Open Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "jjhub.openInBrowser",
        "title": "JJHub: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "jjhub.connectRepo",
        "title": "JJHub: Connect Repository",
        "icon": "$(plug)"
      },
      {
        "command": "jjhub.focusSync",
        "title": "JJHub: Show Sync Status"
      },
      {
        "command": "jjhub.scm.describe",
        "title": "JJ: Describe Change",
        "icon": "$(check)",
        "enablement": "scmProvider == jj"
      },
      {
        "command": "jjhub.scm.new",
        "title": "JJ: New Change",
        "icon": "$(add)",
        "enablement": "scmProvider == jj"
      },
      {
        "command": "jjhub.scm.squash",
        "title": "JJ: Squash",
        "icon": "$(fold)",
        "enablement": "scmProvider == jj"
      },
      {
        "command": "jjhub.scm.abandon",
        "title": "JJ: Abandon Change",
        "icon": "$(trash)",
        "enablement": "scmProvider == jj"
      },
      {
        "command": "jjhub.scm.revertFile",
        "title": "JJ: Revert File",
        "icon": "$(discard)"
      },
      {
        "command": "jjhub.scm.openFile",
        "title": "JJ: Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "jjhub.scm.refresh",
        "title": "JJ: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jjhub",
          "title": "JJHub",
          "icon": "$(git-branch)"
        }
      ]
    },
    "views": {
      "jjhub": [
        {
          "id": "jjhub-issues",
          "name": "Issues"
        },
        {
          "id": "jjhub-landings",
          "name": "Landing Requests"
        },
        {
          "id": "jjhub-bookmarks",
          "name": "Bookmarks"
        },
        {
          "id": "jjhub-sync",
          "name": "Sync Status"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "jjhub.createIssue",
          "when": "view == jjhub-issues",
          "group": "navigation"
        },
        {
          "command": "jjhub.syncNow",
          "when": "view == jjhub-bookmarks",
          "group": "navigation"
        },
        {
          "command": "jjhub.syncNow",
          "when": "view == jjhub-sync",
          "group": "navigation@1"
        },
        {
          "command": "jjhub.connectRepo",
          "when": "view == jjhub-sync",
          "group": "navigation@2"
        }
      ],
      "scm/title": [
        {
          "command": "jjhub.scm.new",
          "when": "scmProvider == jj",
          "group": "navigation@1"
        },
        {
          "command": "jjhub.scm.squash",
          "when": "scmProvider == jj",
          "group": "navigation@2"
        },
        {
          "command": "jjhub.scm.abandon",
          "when": "scmProvider == jj",
          "group": "navigation@3"
        },
        {
          "command": "jjhub.scm.refresh",
          "when": "scmProvider == jj",
          "group": "navigation@4"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "jjhub.scm.openFile",
          "when": "scmProvider == jj",
          "group": "inline@1"
        },
        {
          "command": "jjhub.scm.revertFile",
          "when": "scmProvider == jj",
          "group": "inline@2"
        },
        {
          "command": "jjhub.scm.revertFile",
          "when": "scmProvider == jj",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "JJHub",
      "properties": {
        "jjhub.daemonUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "URL of the JJHub daemon API."
        },
        "jjhub.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the JJHub daemon when the extension activates."
        },
        "jjhub.token": {
          "type": "string",
          "default": "",
          "markdownDescription": "JJHub API token (`jjhub_` prefixed). Leave empty to use the system keychain.",
          "scope": "machine"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
